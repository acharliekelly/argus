{
  "name": "argus-wp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic WordPress update maintenance CLI",
  "bin": {
    "argus": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "ARGUS_DOCKER_INTEGRATION=1 vitest run tests/integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "argus": "tsx src/cli.ts"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "jiti": "^2.6.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.55.0",
    "pngjs": "^7.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.35.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  }
}
